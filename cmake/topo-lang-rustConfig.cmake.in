@PACKAGE_INIT@

# topo-lang-rust CMake package config.
#
# Consumers do:
#     find_package(topo-lang-rust CONFIG REQUIRED)
#     target_link_libraries(<tgt> PRIVATE topo::lang-rust::TopoRustAnalysis)
#
# topo-lang-rust's libs PUBLIC-depend on topo-core (frontend / check /
# transpile / lsp bridge) and topo-lang (plugin framework).

include(CMakeFindDependencyMacro)

if(NOT TARGET topo::core::TopoCheck)
    find_dependency(topo-core CONFIG)
endif()
if(NOT TARGET topo::lang::TopoLang)
    find_dependency(topo-lang CONFIG)
endif()
find_dependency(nlohmann_json CONFIG)

# LLVM scope: TopoRustDriver only resolves once LLVM is on CMAKE_PREFIX_PATH.
set(_topo_lang_rust_llvm_scope @TOPO_LANG_RUST_ENABLE_LLVM@)
if(_topo_lang_rust_llvm_scope)
    find_dependency(LLVM CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/topo-lang-rustTargets.cmake")

check_required_components(topo-lang-rust)
