# Build directories
/build/
/build-*/
/out/
/cmake-build-*/
# Rust / Cargo build artifacts (topo-check/extractor/target/, ...).
# Cargo.lock is NOT ignored — topo-extract-rust is a binary crate, and
# Cargo convention is to commit the lockfile for binaries to keep
# builds reproducible.
target/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
*.cmake.gen

# Compiled objects
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

# Editor / IDE
.vscode/
.idea/
.vs/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Python (test scratch only)
__pycache__/
*.pyc

# vcpkg
vcpkg_installed/
